# Скопируй этот файл в .env и заполни значения.
# Файл .env НЕ должен попадать в git и его нельзя никому показывать.

# Токен бота от @BotFather
TELEGRAM_TOKEN=

# Твой chat_id (см. README, через getUpdates)
TELEGRAM_CHAT_ID=

# Cookie steamLoginSecure из браузера (DevTools -> Application -> Cookies)
STEAM_LOGIN_SECURE=

# Интервал проверки в секундах (необязательно, по умолчанию 180)
CHECK_INTERVAL=180
